\\ncas d'une entreprise.\"),\n      ]),\n      _vm._v(\" \"),\n      _c(\"p\", [\n        _vm._v(\"En cas de dysfonctionnement, il y aura des \"),\n        _c(\"strong\", [_vm._v(\"coûts commerciaux\")]),\n        _vm._v(\" et des \"),\n        _c(\"strong\", [_vm._v(\"coûts de communication\")]),\n        _vm._v(\n          \".\\nIl faudra gérer des crises, prendre du temps pour informer les clients, consommer de la visibilité payante pour regagner de la réputation,\\noffrir des compensations aux clients pour rattraper le coup en cas de mauvais SAV (service Après-Vente), etc.\"\n        ),\n      ]),\n      _vm._v(\" \"),\n      _c(\"p\", [\n        _vm._v(\"Enfin, \"),\n        _c(\"strong\", [_vm._v(\"même vos clients devront payer\")]),\n        _vm._v(\n          \" ! La non-qualité leur coûtera, en temps et en argent : appels sur des numéros\\nsurtaxés, dépenses non prévues, déplacements, temps passé, etc.\"\n        ),\n      ]),\n    ]\n  )\n}\nvar staticRenderFns = []\nrender._withStripped = true\n\nexport { render, staticRenderFns }"],"mappings":"AAAA,IAAIA,MAAM,GAAG,SAASA,MAAM,GAAG;EAC7B,IAAIC,GAAG,GAAG,IAAI;IACZC,EAAE,GAAGD,GAAG,CAACE,KAAK,CAACD,EAAE;EACnB,OAAOA,EAAE,CACP,yBAAyB,EACzB;IAAEE,KAAK,EAAE;MAAE,UAAU,EAAEH,GAAG,CAACI,OAAO,CAACC;IAAQ;EAAE,CAAC,EAC9C,CACEJ,EAAE,CAAC,IAAI,EAAE;IAAEE,KAAK,EAAE;MAAEG,EAAE,EAAE;IAA0C;EAAE,CAAC,EAAE,CACrEL,EAAE,CACA,GAAG,EACH;IACEM,WAAW,EAAE,eAAe;IAC5BJ,KAAK,EAAE;MAAEK,IAAI,EAAE;IAA2C;EAC5D,CAAC,EACD,CAACR,GAAG,CAACS,EAAE,CAAC,GAAG,CAAC,CAAC,CACd,EACDT,GAAG,CAACS,EAAE,CAAC,0CAA0C,CAAC,CACnD,CAAC,EACFT,GAAG,CAACS,EAAE,CAAC,GAAG,CAAC,EACXR,EAAE,CAAC,GAAG,EAAE,CACND,GAAG,CAACS,EAAE,CACJ,oIAAoI,CACrI,CACF,CAAC,EACFT,GAAG,CAACS,EAAE,CAAC,GAAG,CAAC,EACXR,EAAE,CAAC,GAAG,EAAE,CACNA,EAAE,CAAC,QAAQ,EAAE,CACXD,GAAG,CAACS,EAAE,CAAC,iDAAiD,CAAC,CAC1D,CAAC,CACH,CAAC,EACFT,GAAG,CAACS,EAAE,CAAC,GAAG,CAAC,EACXR,EAAE,CAAC,GAAG,EAAE,CACND,GAAG,CAACS,EAAE,CACJ,wEAAwE,CACzE,EACDR,EAAE,CAAC,QAAQ,EAAE,CAACD,GAAG,CAACS,EAAE,CAAC,8CAA8C,CAAC,